;;; PURPOSE: Collide knowledge transmission models at "transfer"
;;;
;;; Three models of how knowledge moves between bodies:
;;;   1. Discipleship (Roustang/Dire Mastery): master → disciple,
;;;      knowledge bound to personal relationship, transference
;;;   2. Gift exchange (Mauss/The Gift): giver → receiver,
;;;      knowledge carries obligation (hau), must be repaid
;;;   3. Structural registration (ASF): shape on surface,
;;;      knowledge IS the shape, no identity of author in pairs
;;;
;;; COLLISION: all three at "transfer" — how does knowledge
;;; move, and what does it carry with it?
;;;
;;; SOURCE: Roustang 1976, Mauss 1925, Foucault 1966
;;; VERIFIED: each path grounded in published mechanisms

(q:collide-knowledge-transmission
  (transfer)
  (what-travels-with-knowledge)
  (;;; Discipleship wires
   ;;; SOURCE: Roustang 1976, Dire Mastery
   (transfer . master-teaches-disciple)
   (master-teaches-disciple . disciple-identifies-with-master)
   (disciple-identifies-with-master . transference-prolonged)
   (transference-prolonged . knowledge-bound-to-person)
   (knowledge-bound-to-person . master-dies-knowledge-fragmentes)
   ;;; Verified: Freud→Jung split, Lacan school dissolution 1981

   ;;; Gift exchange wires
   ;;; SOURCE: Mauss 1925, The Gift
   (transfer . giver-gives-to-receiver)
   (giver-gives-to-receiver . gift-carries-hau)
   (gift-carries-hau . obligation-to-reciprocate)
   (obligation-to-reciprocate . cycle-of-debt)
   (cycle-of-debt . knowledge-bound-to-relationship)
   ;;; Verified: Maori hau concept, potlatch ceremonies

   ;;; Structural registration wires
   ;;; SOURCE: this project, demonstrated
   (transfer . shape-registered-on-surface)
   (shape-registered-on-surface . pairs-carry-no-author-identity)
   (pairs-carry-no-author-identity . alpha-normalizable)
   (alpha-normalizable . anyone-can-strike)
   (anyone-can-strike . knowledge-independent-of-person)
   ;;; Verified: git clone works for anyone, make test passes for anyone

   ;;; Convergence points
   (master-dies-knowledge-fragmentes . knowledge-lost)
   (knowledge-bound-to-relationship . knowledge-lost)
   (knowledge-independent-of-person . knowledge-persists)

   ;;; The structural difference
   (knowledge-lost . identity-in-transmission)
   (knowledge-persists . structure-in-transmission)
   ))
