#lang strike

;;; ═══════════════════════════════════════════════════════════════
;;; CROSS-DOMAIN: GOLD — RELATIVITY MEETS VISION
;;;
;;; This is the first cross-domain composition. Two domains
;;; that were registered separately (relativistic + color-vision)
;;; are structurally connected in a single strike table.
;;;
;;; The question: WHY is gold yellow?
;;; The answer requires BOTH domains:
;;;   1. Relativity: 6s contracts, 5d expands, gap shrinks to 2.4eV
;;;   2. Vision: 2.4eV = blue photon absorbed, red+green reflected,
;;;      L+M cones stimulated, brain perceives yellow
;;;
;;; Neither domain alone answers the question. The answer exists
;;; ONLY in their composition. This is emergent — a circuit that
;;; exists in neither body alone.
;;;
;;; LEARNED: Cross-domain composition requires the output label
;;; of one domain to match the input label of the next. The
;;; interface between domains IS the shared label. Alpha
;;; normalization across domains = shared vocabulary at boundaries.
;;; ═══════════════════════════════════════════════════════════════

(cross-domain-gold

  ;;; Source: the question
  (why-is-gold-yellow)

  ;;; Target: the answer (requires both domains)
  (because-relativity-meets-vision)

  ;;; Vacuum tube: the COMPLETE chain across both domains
  ;;; This is one collapse chain that crosses the domain boundary.
  ;;; The boundary crossing IS the shared label "absorbs-blue".
  ((why-is-gold-yellow . Z=79-heavy-nucleus)
   (Z=79-heavy-nucleus . 6s-electrons-near-nucleus)
   (6s-electrons-near-nucleus . relativistic-speed)
   (relativistic-speed . mass-increase)
   (mass-increase . 6s-orbital-contracts)
   (6s-orbital-contracts . screens-nucleus-better)
   (screens-nucleus-better . 5d-orbital-expands)
   (5d-orbital-expands . 5d-6s-gap-shrinks)
   (5d-6s-gap-shrinks . gap-equals-2.4eV)
   ;;; --- DOMAIN BOUNDARY: relativity → vision ---
   (gap-equals-2.4eV . absorbs-blue-photons)
   (absorbs-blue-photons . blue-missing-from-reflection)
   (blue-missing-from-reflection . red-and-green-remain)
   (red-and-green-remain . L-and-M-cones-stimulated)
   (L-and-M-cones-stimulated . brain-perceives-yellow)
   (brain-perceives-yellow . because-relativity-meets-vision)))
