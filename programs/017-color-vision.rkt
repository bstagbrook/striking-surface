#lang strike

;;; ═══════════════════════════════════════════════════════════════
;;; COLOR AND VISION — ELECTROMAGNETIC SPECTRUM AS DOMAIN
;;;
;;; Light is a waveform. Frequency determines color.
;;; The eye has three cone types (S, M, L) — a structural
;;; basis that creates ALL perceived color from three channels.
;;;
;;; Color space is NOT a property of light. It's a property
;;; of the INTERFACE between light and the eye's structure.
;;; The shape of the receptor IS the shape of the color space.
;;;
;;; This is episteme-rolled: the tool (eye) and the knowledge
;;; (color) are inseparable. Change the receptor structure,
;;; change the color space. Mantis shrimp see 16 channels.
;;; ═══════════════════════════════════════════════════════════════

(tesla-powers-color-vision

  ;;; Source: Tesla — electromagnetic resonance
  ((tesla (spark) (power) ((spark . power))))

  ;;; Target: color/vision domain
  (

    ;;; The electromagnetic spectrum
    (em-spectrum
      (radio-lowest-frequency)
      (gamma-highest-frequency)
      ((radio-lowest-frequency . microwave)
       (microwave . infrared)
       (infrared . visible-light)
       (visible-light . ultraviolet)
       (ultraviolet . x-ray)
       (x-ray . gamma-highest-frequency)))

    ;;; Visible light: the narrow band the eye responds to
    (visible-spectrum
      (red-700nm)
      (violet-400nm)
      ((red-700nm . orange-620nm)
       (orange-620nm . yellow-580nm)
       (yellow-580nm . green-530nm)
       (green-530nm . blue-470nm)
       (blue-470nm . violet-400nm)))

    ;;; Three cone types: the structural basis of color
    (cone-receptors
      (photon-arrives)
      (three-channel-response)
      ((photon-arrives . S-cone-short-blue)
       (S-cone-short-blue . M-cone-medium-green)
       (M-cone-medium-green . L-cone-long-red)
       (L-cone-long-red . three-channel-response)))

    ;;; Color mixing: additive (light) vs subtractive (pigment)
    (additive-mixing
      (red+green+blue)
      (white)
      ((red+green . yellow)
       (green+blue . cyan)
       (red+blue . magenta)
       (red+green+blue . white)))

    ;;; Gold's color: the relativistic domain meets the vision domain
    ;;; This is a CROSS-DOMAIN transform. Relativity (005) meets vision.
    (gold-appears-yellow
      (gap-2.4eV)
      (perceived-yellow)
      ((gap-2.4eV . absorbs-blue)
       (absorbs-blue . reflects-red+green)
       (reflects-red+green . L-M-cones-stimulated)
       (L-M-cones-stimulated . perceived-yellow)))

    ;;; Episteme-rolled: the eye IS the color space
    (eye-is-color-space
      (receptor-structure)
      (perceived-reality)
      ((receptor-structure . three-cones-human)
       (three-cones-human . trichromatic-space)
       (receptor-structure . sixteen-channels-mantis-shrimp)
       (sixteen-channels-mantis-shrimp . hyperspectral-space)
       (receptor-structure . two-cones-dog)
       (two-cones-dog . dichromatic-space)))

  )

  ;;; Vacuum tube
  ((tesla . color-vision-registered)))
